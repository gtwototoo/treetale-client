{
	"name": "treetale-client",
	"version": "0.0.2",
	"private": true,
	"scripts": {
		"dev": "vite dev --host ::",
		"build": "pnpm sync && pnpm lint && vite build",
		"preview": "vite preview --host ::",
		"start": "node -r dotenv/config build",
		"sync": "svelte-kit sync",
		"docker:build": "docker build --no-cache --tag treetale-client .",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin=prettier-plugin-svelte --plugin=prettier-plugin-tailwindcss --write . && eslint .",
		"fix": "prettier --plugin=prettier-plugin-svelte --plugin=prettier-plugin-tailwindcss --write . && eslint . --fix"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.2.0",
		"@sveltejs/kit": "^2.5.18",
		"@sveltejs/vite-plugin-svelte": "^3.1.1",
		"@total-typescript/ts-reset": "^0.5.1",
		"@types/cookie": "^0.6.0",
		"@types/d3-selection": "^3.0.10",
		"@types/howler": "^2.2.11",
		"@types/lodash": "^4.17.7",
		"@types/ms": "^0.7.34",
		"@types/node": "^20.14.11",
		"treetale-ui": "^0.0.7",
		"@typescript-eslint/eslint-plugin": "^7.16.1",
		"@typescript-eslint/parser": "^7.16.1",
		"autoprefixer": "^10.4.19",
		"clsx": "^2.1.1",
		"d3-selection": "^3.0.0",
		"deep-object-diff": "^1.1.9",
		"dotenv": "^16.4.5",
		"embla-carousel": "8.1.6",
		"embla-carousel-svelte": "8.1.6",
		"eslint": "^9.7.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-perfectionist": "^2.11.0",
		"eslint-plugin-svelte": "^2.42.0",
		"howler": "^2.2.4",
		"lodash": "^4.17.21",
		"ms": "^2.1.3",
		"globals": "^15.8.0",
		"postcss": "^8.4.39",
		"postcss-load-config": "^6.0.1",
		"prettier": "^3.3.3",
		"prettier-plugin-svelte": "^3.2.5",
		"prettier-plugin-tailwindcss": "^0.6.5",
		"schema-dts": "^1.1.2",
		"svelte": "^5.0.0-next.183",
		"svelte-check": "^3.8.4",
		"svelte-heros-v2": "^1.3.0",
		"svelte-preprocess": "^6.0.2",
		"svelte-sound": "^0.6.0",
		"tailwind-merge": "^2.4.0",
		"tailwindcss": "^3.4.6",
		"tslib": "^2.6.3",
		"typescript": "^5.5.3",
		"vite": "^5.3.4",
		"pluralize-ru-ts": "^1.1.0"
	},
	"type": "module"
}
