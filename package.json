{
	"name": "treetale-client",
	"version": "0.0.2",
	"private": true,
	"scripts": {
		"dev": "vite dev --host ::",
		"build": "pnpm sync && pnpm lint && vite build",
		"preview": "vite preview --host ::",
		"start": "node -r dotenv/config build",
		"sync": "svelte-kit sync",
		"docker::build": "docker build --no-cache --tag treetale-client .",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin=prettier-plugin-svelte --plugin=prettier-plugin-tailwindcss --write . && eslint .",
		"fix": "prettier --plugin=prettier-plugin-svelte --plugin=prettier-plugin-tailwindcss --write . && eslint . --fix"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^4.0.1",
		"@sveltejs/kit": "^2.5.0",
		"@sveltejs/vite-plugin-svelte": "^3.0.0",
		"@sveltekit-addons/document": "^1.0.1",
		"@total-typescript/ts-reset": "^0.5.1",
		"@types/cookie": "^0.6.0",
		"@types/howler": "^2.2.11",
		"@types/lodash": "^4.14.202",
		"@types/ms": "^0.7.34",
		"@types/node": "^20.11.9",
		"@typescript-eslint/eslint-plugin": "^6.19.1",
		"@typescript-eslint/parser": "^6.19.1",
		"autoprefixer": "^10.4.17",
		"clsx": "^2.1.0",
		"deep-object-diff": "^1.1.9",
		"dotenv": "^16.4.1",
		"embla-carousel": "8.0.0-rc21",
		"embla-carousel-svelte": "8.0.0-rc21",
		"eslint": "^8.56.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-perfectionist": "^2.5.0",
		"eslint-plugin-svelte": "^2.35.1",
		"howler": "^2.2.4",
		"lodash": "^4.17.21",
		"ms": "^2.1.3",
		"postcss": "^8.4.33",
		"postcss-load-config": "^5.0.2",
		"prettier": "^3.2.4",
		"prettier-plugin-svelte": "^3.1.2",
		"prettier-plugin-tailwindcss": "^0.5.11",
		"svelte": "^4.2.9",
		"svelte-check": "^3.6.3",
		"svelte-heros-v2": "^1.2.0",
		"svelte-meta-tags": "^3.1.0",
		"svelte-preprocess": "^5.1.3",
		"svelte-sound": "^0.6.0",
		"tailwind-merge": "^2.2.1",
		"tailwindcss": "^3.4.1",
		"tslib": "^2.6.2",
		"typescript": "^5.3.3",
		"vite": "^5.0.12"
	},
	"type": "module"
}
