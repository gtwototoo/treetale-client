{
	"name": "treetale-client",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev --host ::",
		"build": "pnpm sync && pnpm lint && vite build",
		"preview": "vite preview --host ::",
		"sync": "svelte-kit sync",
		"docker::build": "docker build --no-cache --tag treetale-client .",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin=prettier-plugin-svelte --plugin=prettier-plugin-tailwindcss --write . && eslint .",
		"fix": "prettier --plugin=prettier-plugin-svelte --plugin=prettier-plugin-tailwindcss --write . && eslint . --fix"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^1.3.1",
		"@sveltejs/kit": "^1.27.6",
		"@sveltekit-addons/document": "^1.0.1",
		"@total-typescript/ts-reset": "^0.5.1",
		"@types/dompurify": "^3.0.5",
		"@types/ms": "^0.7.34",
		"@types/object-path": "^0.11.4",
		"@typescript-eslint/eslint-plugin": "^6.11.0",
		"@typescript-eslint/parser": "^6.11.0",
		"autoprefixer": "^10.4.16",
		"clsx": "^2.0.0",
		"dompurify": "^3.0.6",
		"embla-carousel-svelte": "^8.0.0-rc15",
		"eslint": "^8.53.0",
		"eslint-config-prettier": "^9.0.0",
		"eslint-plugin-perfectionist": "^2.3.0",
		"eslint-plugin-svelte": "^2.35.0",
		"isomorphic-dompurify": "^1.9.0",
		"ms": "^2.1.3",
		"object-path": "^0.11.8",
		"postcss": "^8.4.31",
		"postcss-load-config": "^4.0.1",
		"prettier": "^3.1.0",
		"prettier-plugin-svelte": "^3.1.0",
		"prettier-plugin-tailwindcss": "^0.5.7",
		"svelte": "^4.2.3",
		"svelte-check": "^3.6.0",
		"svelte-gestures": "^1.5.2",
		"svelte-heros-v2": "^0.10.12",
		"svelte-preprocess": "^5.1.0",
		"tailwind-merge": "^2.0.0",
		"tailwindcss": "^3.3.5",
		"tslib": "^2.6.2",
		"typescript": "^5.2.2",
		"vite": "^4.5.0"
	},
	"type": "module",
	"dependencies": {
		"@types/cookie": "^0.6.0",
		"mongoose": "^8.0.0"
	}
}
