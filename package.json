{
	"name": "treetale-client",
	"version": "0.0.2",
	"private": true,
	"scripts": {
		"dev": "vite dev --host ::",
		"build": "svelte-kit sync && pnpm lint && vite build",
		"preview": "vite preview --host ::",
		"start": "node -r dotenv/config build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin=prettier-plugin-svelte --plugin=prettier-plugin-tailwindcss --write . && eslint .",
		"fix": "prettier --plugin=prettier-plugin-svelte --plugin=prettier-plugin-tailwindcss --write . && eslint . --fix",
		"docker:build": "docker build --no-cache --tag treetale-board ."
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.2.11",
		"@sveltejs/kit": "^2.14.0",
		"@sveltejs/vite-plugin-svelte": "5.0.3",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/d3-selection": "^3.0.11",
		"@types/howler": "^2.2.12",
		"@types/lodash": "^4.17.13",
		"@types/ms": "^0.7.34",
		"@types/node": "^22.10.2",
		"@typescript-eslint/eslint-plugin": "^8.18.1",
		"@typescript-eslint/parser": "^8.18.1",
		"autoprefixer": "^10.4.20",
		"clsx": "^2.1.1",
		"d3-selection": "^3.0.0",
		"deep-object-diff": "^1.1.9",
		"dotenv": "^16.4.7",
		"embla-carousel": "8.5.1",
		"embla-carousel-svelte": "8.5.1",
		"eslint": "^9.17.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-svelte": "^2.46.1",
		"globals": "^15.14.0",
		"howler": "^2.2.4",
		"lodash": "^4.17.21",
		"ms": "^2.1.3",
		"pluralize-ru-ts": "^1.1.0",
		"postcss": "^8.4.49",
		"postcss-load-config": "^6.0.1",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.2",
		"prettier-plugin-tailwindcss": "^0.6.9",
		"schema-dts": "^1.1.2",
		"svelte": "5.15.0",
		"svelte-check": "^4.1.1",
		"svelte-heros-v2": "^2.0.1",
		"svelte-preprocess": "^6.0.3",
		"svelte-sound": "^0.6.0",
		"tailwind-merge": "^2.5.5",
		"tailwindcss": "^3.4.17",
		"treetale-ui": "^0.2.9",
		"tslib": "^2.8.1",
		"typescript": "^5.7.2",
		"typescript-eslint": "^8.18.1",
		"vite": "^6.0.5"
	},
	"type": "module",
	"dependencies": {
		"svelte-meta-tags": "^4.0.4"
	}
}
