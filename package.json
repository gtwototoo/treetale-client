{
	"name": "treetale-client",
	"version": "0.0.2",
	"private": true,
	"scripts": {
		"dev": "vite dev --host ::",
		"build": "svelte-kit sync && pnpm lint && vite build",
		"preview": "vite preview --host ::",
		"start": "node -r dotenv/config build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin=prettier-plugin-svelte --plugin=prettier-plugin-tailwindcss --write . && eslint .",
		"fix": "prettier --plugin=prettier-plugin-svelte --plugin=prettier-plugin-tailwindcss --write . && eslint . --fix",
		"docker:build": "docker build --no-cache --tag treetale-board ."
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.2.6",
		"@sveltejs/kit": "^2.7.0",
		"@sveltejs/vite-plugin-svelte": "4.0.0-next.8",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/cookie": "^0.6.0",
		"@types/d3-selection": "^3.0.11",
		"@types/howler": "^2.2.12",
		"@types/lodash": "^4.17.10",
		"@types/ms": "^0.7.34",
		"@types/node": "^22.7.5",
		"@typescript-eslint/eslint-plugin": "^8.9.0",
		"@typescript-eslint/parser": "^8.9.0",
		"autoprefixer": "^10.4.20",
		"clsx": "^2.1.1",
		"d3-selection": "^3.0.0",
		"deep-object-diff": "^1.1.9",
		"dotenv": "^16.4.5",
		"embla-carousel": "8.3.0",
		"embla-carousel-svelte": "8.3.0",
		"eslint": "^9.12.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-svelte": "^2.44.1",
		"globals": "^15.11.0",
		"howler": "^2.2.4",
		"lodash": "^4.17.21",
		"ms": "^2.1.3",
		"pluralize-ru-ts": "^1.1.0",
		"postcss": "^8.4.47",
		"postcss-load-config": "^6.0.1",
		"prettier": "^3.3.3",
		"prettier-plugin-svelte": "^3.2.7",
		"prettier-plugin-tailwindcss": "^0.6.8",
		"schema-dts": "^1.1.2",
		"svelte": "5.0.0-next.264",
		"svelte-check": "^4.0.5",
		"svelte-heros-v2": "^1.3.0",
		"svelte-preprocess": "^6.0.3",
		"svelte-sound": "^0.6.0",
		"tailwind-merge": "^2.5.3",
		"tailwindcss": "^3.4.13",
		"treetale-ui": "^0.2.7",
		"tslib": "^2.7.0",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.8.1",
		"vite": "^5.4.8"
	},
	"type": "module"
}
