		"svelte-gestures": "^1.5.2",
		"svelte-heros-v2": "^0.7.4",
		"svelte-preprocess": "^5.0.4",
		"tailwind-merge": "^1.14.0",
		"tailwindcss": "^3.3.3",
		"tslib": "^2.6.1",
		"typescript": "^5.1.6",
		"vite": "^4.4.7"
	},
	"type": "module",
	"dependencies": {
		"mongoose": "^7.4.1",
		"uuid": "^9.0.0"
